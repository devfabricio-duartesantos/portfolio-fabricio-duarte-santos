rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Bootstrap Admin: fabricioduart444@gmail.com
    function isAdmin() {
      return isSignedIn() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        request.auth.token.email == 'fabricioduart444@gmail.com'
      );
    }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 256 &&
             data.role in ['admin', 'user'] &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() <= 128)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 512));
    }

    function isValidQRCode(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.data is string && data.data.size() > 0 && data.data.size() <= 10000 &&
             data.options is map &&
             data.createdBy == request.auth.uid &&
             data.createdAt == request.time;
    }

    function isValidHistory(data) {
      return data.data is string && data.data.size() > 0 && data.data.size() <= 10000 &&
             data.format is string && data.format.size() > 0 && data.format.size() <= 10 &&
             data.userId == request.auth.uid &&
             data.createdAt == request.time;
    }

    // --- Collections ---

    match /history/{historyId} {
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow get: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow create: if isEmailVerified() && isValidHistory(incoming());
      allow delete: if isAdmin(); // Only admins can delete history for now
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      allow create: if isOwner(userId) && 
                      isValidUser(incoming()) && 
                      incoming().role == 'user'; // Users can't make themselves admins
                      
      allow update: if (isOwner(userId) || isAdmin()) && 
                      isValidUser(incoming()) && (
                        (isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['role', 'displayName', 'photoURL'])) ||
                        (isOwner(userId) && incoming().role == existing().role && 
                         incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL']))
                      );
    }

    match /qrcodes/{qrcodeId} {
      allow get: if isSignedIn() && (existing().createdBy == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.createdBy == request.auth.uid || isAdmin());
      
      allow create: if isEmailVerified() && 
                      isValidId(qrcodeId) && 
                      isValidQRCode(incoming());
                      
      allow update: if isEmailVerified() && 
                      existing().createdBy == request.auth.uid && 
                      isValidQRCode(incoming()) &&
                      incoming().createdAt == existing().createdAt &&
                      incoming().createdBy == existing().createdBy &&
                      incoming().diff(existing()).affectedKeys().hasOnly(['name', 'data', 'options']);
                      
      allow delete: if isEmailVerified() && (existing().createdBy == request.auth.uid || isAdmin());
    }
  }
}
